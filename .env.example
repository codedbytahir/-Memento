# --- AWS AUTHENTICATION (Hackathon Sandbox) ---
# Heads up: These 3 values expire! If you get "ExpiredToken", 
# grab a fresh set from your AWS Access Portal.
AWS_ACCESS_KEY_ID="!lll....YOURKEY"
AWS_SECRET_ACCESS_KEY="YOUR_KEY"
AWS_SESSION_TOKEN="YOUR_KEY"
AWS_REGION="eu-north-1"

# --- APPLICATION SETTINGS ---
# Set to "false" to ensure we are actually hitting the AWS services we built
NEXT_PUBLIC_DEV_MODE="false"

# --- DYNAMODB TABLES ---
# We renamed the code's keys to "id" to match these tables
SESSIONS_TABLE="YOURs"
CONNECTIONS_TABLE="YOURs"

# --- S3 BUCKETS ---
IMAGES_BUCKET="Yours"
PDF_BUCKET="Yours"

# --- SQS QUEUE ---
PROCESSING_QUEUE_URL="Yours"

# --- WEBSOCKET API ---
# This is the "wss" link for the frontend to talk to the Nova model
WEBSOCKET_URL="Yours"

